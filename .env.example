# Database Configuration
DB_NAME=hypertube_db
DB_USER=hypertube
DB_PASSWORD=your_db_password 
DB_HOST=database
DB_PORT=5432

# Application Configuration
APP_URL=http://localhost:5000
DEBUG=True
FLASK_ENV=development

# API config for OpenAPI
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=5000
API_TITLE=Hypertube API
API_TYPE=http

OPENAPI_VERSION=3.0.2
OPENAPI_URL_PREFIX=/api
OPENAPI_SWAGGER_UI_PATH=/docs
OPENAPI_SWAGGER_UI_URL=https://cdn.jsdelivr.net/npm/swagger-ui-dist@3/
TOKEN_SCHEME=bearer
BEARER_FORMAT=JWT

# Auth / JWT
JWT_SECRET_KEY=your_jwt_secret_key_ — generate with: openssl rand -hex 32
JWT_ACCESS_EXPIRES_MINUTES=120
JWT_REFRESH_EXPIRES_DAYS=30

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# DNS
DNS_PRIMARY=8.8.8.8
DNS_SECONDARY=8.8.4.4

# External APIs URLs (overridable for testing/proxies)
YTS_BASE_URL=https://yts.lt/api/v2
EZTV_BASE_URL=https://eztvx.to/api
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# TMDb API Configuration
# Get your free API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Request timeout (seconds)
PROVIDER_TIMEOUT=10
MAX_RESULTS_PER_PROVIDER=50

# Nginx
NGINX_STREAMING_ENABLED=true

# qBittorrent (linuxserver/qbittorrent image settings)
QB_PUID=1000
QB_PGID=1000
QB_WEBUI_PORT=8080
QB_TZ=Europe/Paris

# qBittorrent credentials (used by Celery worker)
QBITTORRENT_HOST=http://qbittorrent:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=your_qbittorrent_p
TORRENTING_PORT=6881