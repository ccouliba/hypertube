# Database Configuration
DB_USER=hypertube
DB_PASSWORD=your_hypertube_db_password
DB_HOST=database
DB_PORT=5432
DB_NAME=your_hypertube_db_name

# Application Configuration
APP_URL=http://localhost:5000
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=True
FLASK_ENV=development

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# External APIs URLs (overridable for testing/proxies)
YTS_BASE_URL=https://yts.lt/api/v2
EZTV_BASE_URL=https://eztvx.to/api
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# TMDb API Configuration
# Get your free API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
ACCESS_READING_TOKEN=your_access_reading_token

# Request timeout (seconds)
PROVIDER_TIMEOUT=10
MAX_RESULTS_PER_PROVIDER=50
